# 주담 AI 서버 환경변수 템플릿
# 실제 키 값으로 채운 뒤 ".env" 로 복사하세요. .env 는 절대 커밋 금지(.gitignore 처리됨).
# cp .env.example .env

# ── 필수/권장 ──
GEMINI_API_KEY=             # Gemini 기능(레시피/법률/챗봇/이미지/OCR) 필수
LAW_API_KEY=                # 국가법령정보센터 OPEN API OC(이메일 ID). 없으면 내장 법령 fallback
NONGSARO_API_KEY=           # 농사로 지역특산물 수집 스크립트(collect_local_products.py)

# ── 법령 RAG / 법령 API 옵션 ──
LAW_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2   # 조문 임베딩 모델(교체 시 --rebuild)
LAW_USER_AGENT=             # 비우면 기본 브라우저 UA 사용 (law.go.kr 호출 헤더)
LAW_REFERER=https://www.law.go.kr/                       # law.go.kr 호출 Referer 헤더

# ── 데이터/캐시 (선택) ──
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/juddam   # 없으면 인메모리+JSON fallback
REDIS_URL=redis://localhost:6379                          # 선택(캐시)
HUGGINGFACE_TOKEN=          # 선택(이미지 생성 Gemini 실패 시 SD fallback)

# ── AWS SQS 워커 (선택, app/sqs_worker.py 실행 시만) ──
AWS_REGION=ap-northeast-2
AWS_SQS_AI_TASK_QUEUE_URL=

# ── 서버 ──
LOG_LEVEL=INFO
PORT=8000
