# 주담 AI 서버 - 환경변수 설정 예시
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요

# Gemini API 키
GEMINI_API_KEY=your_gemini_api_key_here

# 국가법령정보센터 API 키
LAW_API_KEY=your_law_api_key_here

# 데이터베이스 URL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/juddam

# Redis URL
REDIS_URL=redis://localhost:6379

# 로그 레벨
LOG_LEVEL=INFO

# 서버 포트
PORT=8000
